<Window x:Class="Ct3xxSimulator.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewModels="clr-namespace:Ct3xxSimulator.Desktop.ViewModels"
        mc:Ignorable="d"
        Title="CT3xx Visual Simulator"
        Height="820"
        Width="1280">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <Style TargetType="{x:Type TreeViewItem}">
            <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#FF293241"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type TreeViewItem}">
                        <Grid SnapsToDevicePixels="True">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <ToggleButton x:Name="Expander"
                                          Grid.Row="0"
                                          Grid.Column="0"
                                          Width="18"
                                          Height="18"
                                          Margin="0,7,6,0"
                                          Padding="0"
                                          Focusable="False"
                                          IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}}"
                                          ClickMode="Press"
                                          Background="Transparent"
                                          BorderBrush="Transparent"
                                          FocusVisualStyle="{x:Null}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="{x:Type ToggleButton}">
                                        <Border Background="Transparent"
                                                BorderBrush="Transparent"
                                                BorderThickness="0"
                                                Padding="0"
                                                SnapsToDevicePixels="True">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                                <Grid Width="18" Height="18">
                                    <Grid x:Name="FolderClosedIcon">
                                        <Viewbox Width="16" Height="16" Stretch="Uniform">
                                            <Canvas Width="16" Height="16">
                                                <Ellipse Canvas.Left="1.4"
                                                         Canvas.Top="1.4"
                                                         Width="13.2"
                                                         Height="13.2"
                                                         Stroke="#FF5C6673"
                                                         StrokeThickness="1.2"/>
                                                <Path Stroke="#FF5C6673"
                                                      StrokeThickness="1.4"
                                                      StrokeStartLineCap="Round"
                                                      StrokeEndLineCap="Round"
                                                      StrokeLineJoin="Round"
                                                      Data="M 6.2,5.2 L 9.4,8 L 6.2,10.8"/>
                                            </Canvas>
                                        </Viewbox>
                                    </Grid>
                                    <Grid x:Name="FolderOpenIcon"
                                          Visibility="Collapsed">
                                        <Viewbox Width="16" Height="16" Stretch="Uniform">
                                            <Canvas Width="16" Height="16">
                                                <Ellipse Canvas.Left="1.4"
                                                         Canvas.Top="1.4"
                                                         Width="13.2"
                                                         Height="13.2"
                                                         Stroke="#FF5C6673"
                                                         StrokeThickness="1.2"/>
                                                <Path Stroke="#FF5C6673"
                                                      StrokeThickness="1.4"
                                                      StrokeStartLineCap="Round"
                                                      StrokeEndLineCap="Round"
                                                      StrokeLineJoin="Round"
                                                      Data="M 5.2,6.4 L 8,9.6 L 10.8,6.4"/>
                                            </Canvas>
                                        </Viewbox>
                                    </Grid>
                                </Grid>
                            </ToggleButton>

                            <Border x:Name="SelectionBorder"
                                    Grid.Row="0"
                                    Grid.Column="1"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="6">
                                <ContentPresenter ContentSource="Header"/>
                            </Border>

                            <ItemsPresenter x:Name="ItemsHost"
                                            Grid.Row="1"
                                            Grid.Column="1"
                                            Margin="18,0,0,0"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="HasItems" Value="False">
                                <Setter TargetName="Expander" Property="Visibility" Value="Hidden"/>
                            </Trigger>
                            <Trigger Property="IsExpanded" Value="False">
                                <Setter TargetName="ItemsHost" Property="Visibility" Value="Collapsed"/>
                                <Setter TargetName="FolderClosedIcon" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="FolderOpenIcon" Property="Visibility" Value="Collapsed"/>
                            </Trigger>
                            <Trigger Property="IsExpanded" Value="True">
                                <Setter TargetName="FolderClosedIcon" Property="Visibility" Value="Collapsed"/>
                                <Setter TargetName="FolderOpenIcon" Property="Visibility" Value="Visible"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#00000000"/>
                    <Setter Property="BorderBrush" Value="#FFE2E8EF"/>
                    <Setter Property="BorderThickness" Value="1"/>
                    <Setter Property="Foreground" Value="#FF293241"/>
                </Trigger>
                <MultiTrigger>
                    <MultiTrigger.Conditions>
                        <Condition Property="IsSelected" Value="True"/>
                        <Condition Property="IsSelectionActive" Value="False"/>
                    </MultiTrigger.Conditions>
                    <Setter Property="Background" Value="#00000000"/>
                    <Setter Property="BorderBrush" Value="#FFE2E8EF"/>
                    <Setter Property="BorderThickness" Value="1"/>
                    <Setter Property="Foreground" Value="#FF293241"/>
                </MultiTrigger>
            </Style.Triggers>
        </Style>
        <HierarchicalDataTemplate DataType="{x:Type viewModels:StepTreeNodeViewModel}" ItemsSource="{Binding Children}">
            <Border x:Name="NodeBorder" Margin="0,0,0,6" Padding="8" Background="#FFFDFEFE" BorderBrush="#FFE2E8EF" BorderThickness="1" CornerRadius="6">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2.7*"/>
                        <ColumnDefinition Width="0.8*"/>
                        <ColumnDefinition Width="1.2*"/>
                        <ColumnDefinition Width="1.5*"/>
                    </Grid.ColumnDefinitions>
                    <Border x:Name="NodeSelectionAccent"
                            Width="3"
                            Margin="-8,-8,0,-8"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Stretch"
                            Background="#00000000"
                            CornerRadius="2"
                            IsHitTestVisible="False"/>

                    <StackPanel Grid.Column="0">
                        <DockPanel LastChildFill="True">
                            <Border DockPanel.Dock="Right"
                                    Margin="8,0,0,0"
                                    Padding="6,2"
                                    Background="#FFFDEDEE"
                                    BorderBrush="#FFE8C8CC"
                                    BorderThickness="1"
                                    CornerRadius="9"
                                    Visibility="{Binding HasBreakpoint, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <TextBlock FontSize="10" FontWeight="Bold" Foreground="#FF8B1E3F" Text="{Binding BreakpointText}"/>
                            </Border>
                            <TextBlock FontWeight="SemiBold" Foreground="#FF293241" Text="{Binding Title}" TextWrapping="Wrap"/>
                        </DockPanel>
                        <TextBlock Margin="0,3,0,0" FontSize="11" Foreground="#FF6B7480" Text="{Binding NodeTypeLabel}"/>
                    </StackPanel>

                    <Border Grid.Column="1"
                            Margin="10,0,0,0"
                            Padding="8,3"
                            HorizontalAlignment="Left"
                            Background="{Binding OutcomeBadgeBackground}"
                            BorderBrush="#FFD7E3EF"
                            BorderThickness="1"
                            CornerRadius="10">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock FontWeight="Bold" Foreground="{Binding OutcomeBadgeForeground}" Text="{Binding Outcome}"/>
                            <TextBlock Margin="6,0,0,0"
                                       FontSize="10"
                                       FontWeight="SemiBold"
                                       Foreground="{Binding OutcomeBadgeForeground}"
                                       Text="{Binding ResultSourceLabel}"
                                       Visibility="{Binding HasResultSourceLabel, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                        </StackPanel>
                    </Border>

                    <TextBlock Grid.Column="2"
                               Margin="12,0,0,0"
                               VerticalAlignment="Center"
                               Foreground="#FF3B4652"
                               Text="{Binding ValueSummary}"
                               TextWrapping="Wrap"/>

                    <TextBlock Grid.Column="3"
                               Margin="12,0,0,0"
                               VerticalAlignment="Center"
                               Foreground="#FF5E6772"
                               Text="{Binding RangeSummary}"
                               TextWrapping="Wrap"/>
                </Grid>
            </Border>
            <HierarchicalDataTemplate.Triggers>
                <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=TreeViewItem}, Path=IsSelected}" Value="True">
                    <Setter TargetName="NodeSelectionAccent" Property="Background" Value="#FF5A8FC9"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding IsGroup}" Value="True">
                    <Setter TargetName="NodeBorder" Property="Background" Value="#FFF6F8FB"/>
                    <Setter TargetName="NodeBorder" Property="BorderBrush" Value="#FFD9E2EC"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding IsGroup}" Value="True">
                    <Setter TargetName="NodeBorder" Property="Padding" Value="10"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding GroupMode}" Value="Concurrent">
                    <Setter TargetName="NodeBorder" Property="Background" Value="#FFF6FBF7"/>
                    <Setter TargetName="NodeBorder" Property="BorderBrush" Value="#FFCBE5D2"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding GroupMode}" Value="Concurrent Loop">
                    <Setter TargetName="NodeBorder" Property="Background" Value="#FFF5FBF5"/>
                    <Setter TargetName="NodeBorder" Property="BorderBrush" Value="#FFC3DDC7"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding GroupMode}" Value="Loop">
                    <Setter TargetName="NodeBorder" Property="Background" Value="#FFFBF9F3"/>
                    <Setter TargetName="NodeBorder" Property="BorderBrush" Value="#FFE5D7B2"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding GroupMode}" Value="Test Loop">
                    <Setter TargetName="NodeBorder" Property="Background" Value="#FFF4F7FB"/>
                    <Setter TargetName="NodeBorder" Property="BorderBrush" Value="#FFCBD8E7"/>
                </DataTrigger>
            </HierarchicalDataTemplate.Triggers>
        </HierarchicalDataTemplate>
    </Window.Resources>
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="220"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Padding="12" Background="#FFF5F7FA" BorderBrush="#FFD7DEE7" BorderThickness="1" CornerRadius="8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Text="Szenario"/>
                <ComboBox Grid.Row="0" Grid.Column="1" Margin="10,0,10,8" ItemsSource="{Binding ScenarioPresets}" SelectedItem="{Binding SelectedScenarioPreset}" DisplayMemberPath="Name"/>
                <StackPanel Grid.Row="0" Grid.Column="2" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Margin="0,0,8,8" Padding="14,8" Content="Laden" Click="OnApplyScenarioPreset"/>
                    <Button Margin="0,0,8,8" Padding="14,8" Content="Speichern" Click="OnSaveScenarioPreset"/>
                    <Button Margin="0,0,8,8" Padding="14,8" Content="Upgrade" Click="OnUpgradeScenarioPreset"/>
                    <Button Margin="0,0,0,8" Padding="14,8" Content="Loeschen" Click="OnDeleteScenarioPreset"/>
                </StackPanel>

                <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Text="Szenario-Datei"/>
                <TextBox Grid.Row="1" Grid.Column="1" Margin="10,0,10,8" Text="{Binding ScenarioPresetFilePath, UpdateSourceTrigger=PropertyChanged}"/>
                <StackPanel Grid.Row="1" Grid.Column="2" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Margin="0,0,8,8" Padding="14,8" Content="Datei..." Click="OnBrowseScenarioPresetFile"/>
                    <Button Margin="0,0,8,8" Padding="14,8" Content="Datei laden" Click="OnLoadScenarioPresetFile"/>
                    <Button Margin="0,0,0,8" Padding="14,8" Content="Speichern unter" Click="OnSaveScenarioPresetFileAs"/>
                </StackPanel>

                <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Text="Testprogramm-Ordner"/>
                <TextBox Grid.Row="2" Grid.Column="1" Margin="10,0,10,8" Text="{Binding TestProgramFolderPath, UpdateSourceTrigger=PropertyChanged}"/>
                <Button Grid.Row="2" Grid.Column="2" Margin="0,0,8,8" Padding="14,8" Content="Ordner..." Click="OnBrowseProgramFolder"/>
                <Button Grid.Row="2" Grid.Column="3" Margin="0,0,0,8" Padding="14,8" Content="Programm laden" Click="OnLoadProgramFromResolvedSelection" AutomationProperties.AutomationId="LoadProgramButton"/>

                <TextBlock Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" Text="Verdrahtungs-Ordner"/>
                <TextBox Grid.Row="3" Grid.Column="1" Margin="10,0,10,8" Text="{Binding WiringFolderPath, UpdateSourceTrigger=PropertyChanged}"/>
                <Button Grid.Row="3" Grid.Column="2" Grid.ColumnSpan="2" Margin="0,0,0,8" Padding="14,8" Content="Ordner..." Click="OnBrowseWiringFolder"/>

                <TextBlock Grid.Row="4" Grid.Column="0" VerticalAlignment="Center" Text="Simulations-Ordner"/>
                <TextBox Grid.Row="4" Grid.Column="1" Margin="10,0,10,8" Text="{Binding SimulationModelFolderPath, UpdateSourceTrigger=PropertyChanged}"/>
                <Button Grid.Row="4" Grid.Column="2" Grid.ColumnSpan="2" Margin="0,0,0,8" Padding="14,8" Content="Ordner..." Click="OnBrowseSimulationModelFolder"/>

                <TextBlock Grid.Row="5" Grid.Column="0" VerticalAlignment="Center" Text="Geraetemodell / Python"/>
                <TextBox Grid.Row="5" Grid.Column="1" Margin="10,0,10,8" Text="{Binding PythonScriptPath, UpdateSourceTrigger=PropertyChanged}"/>
                <Button Grid.Row="5" Grid.Column="2" Grid.ColumnSpan="2" Margin="0,0,0,8" Padding="14,8" Content="Datei..." Click="OnBrowsePythonScript"/>

                <TextBlock Grid.Row="6" Grid.Column="0" VerticalAlignment="Center" Text="CSV-Testlauf"/>
                <TextBox Grid.Row="6" Grid.Column="1" Margin="10,0,10,8" Text="{Binding CsvReplayFilePath, UpdateSourceTrigger=PropertyChanged}"/>
                <StackPanel Grid.Row="6" Grid.Column="2" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Margin="0,0,8,8" Padding="14,8" Content="Datei..." Click="OnBrowseCsvReplayFile"/>
                    <ComboBox Width="170"
                              Margin="0,0,0,8"
                              ItemsSource="{Binding CsvReplayModeOptions}"
                              SelectedValue="{Binding SelectedCsvReplayMode}"
                              SelectedValuePath="Key"
                              DisplayMemberPath="Value"/>
                </StackPanel>

                <TextBlock Grid.Row="7" Grid.Column="0" VerticalAlignment="Center" Text="Aufgeloestes Programm"/>
                <TextBox Grid.Row="7" Grid.Column="1" Margin="10,0,10,0" Text="{Binding SelectedFilePath}" IsReadOnly="True" AutomationProperties.AutomationId="ProgramPathBox"/>
                <StackPanel Grid.Row="7" Grid.Column="2" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right">
                    <CheckBox Margin="0,0,8,0" VerticalAlignment="Center" IsChecked="{Binding IsStepModeEnabled}" Content="Einzelschritt"/>
                    <Button Margin="0,0,8,0" Padding="14,8" Content="Zurueck" Click="OnStepBack" IsEnabled="{Binding CanStepBackward}"/>
                    <Button Margin="0,0,8,0" Padding="14,8" Content="Weiter" Click="OnContinueStep"/>
                    <Button Margin="0,0,8,0" Padding="14,8" Content="Auto" Click="OnResumeAutomaticRun"/>
                    <Button Margin="0,0,8,0" Padding="14,8" Content="Pause" Click="OnPauseAtNextStep"/>
                    <Button Margin="0,0,8,0" Padding="14,8" Content="Validieren" Click="OnValidateConfiguration"/>
                    <Button Margin="0,0,8,0" Padding="14,8" Content="Live-Zustand" Click="OnShowLiveState"/>
                    <Button Margin="0,0,8,0" Padding="14,8" Content="Simulation starten" Click="OnStartSimulation" IsEnabled="{Binding CanStartSimulation}" AutomationProperties.AutomationId="StartSimulationButton"/>
                    <Button Padding="14,8" Content="Abbrechen" Click="OnCancelSimulation" IsEnabled="{Binding IsSimulationRunning}" AutomationProperties.AutomationId="CancelSimulationButton"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Margin="0,12,0,12" Padding="12" Background="#FFFFFBF2" BorderBrush="#FFE6D6A8" BorderThickness="1" CornerRadius="8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock FontWeight="Bold" Text="Aktive Konfiguration"/>
                    <TextBlock Margin="0,4,0,0" Text="{Binding ConfigurationSummary}" TextWrapping="Wrap"/>
                    <TextBlock Margin="0,4,0,0" FontWeight="Bold" Text="{Binding ValidationSummary}" TextWrapping="Wrap"/>
                    <TextBlock Margin="0,4,0,0" FontWeight="Bold" Foreground="#FF375A7F" Text="{Binding CsvReplaySummary}" TextWrapping="Wrap"/>
                    <TextBlock Margin="0,4,0,0" Foreground="#FF5A6470" Text="Wenn im Testprogramm-Ordner mehrere .ctxprg liegen, fragt die App beim Laden nach der gewuenschten Datei. Beim Geraetemodell sind .py, .json, .yaml und .yml moeglich." TextWrapping="Wrap"/>
                </StackPanel>
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock FontWeight="Bold" Text="Aktueller Schritt"/>
                    <TextBlock Margin="0,4,0,0" FontSize="16" Text="{Binding CurrentStep, TargetNullValue=-}"/>
                    <Border Margin="0,8,0,0"
                            Padding="8,3"
                            HorizontalAlignment="Left"
                            Background="#FFF7F9FB"
                            BorderBrush="#FFD9E1E8"
                            BorderThickness="1"
                            CornerRadius="10">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="8"
                                     Height="8"
                                     Margin="0,0,6,0"
                                     VerticalAlignment="Center"
                                     Fill="{Binding SimulationRunStateBrush}"/>
                            <TextBlock FontWeight="SemiBold"
                                       Foreground="#FF3B4652"
                                       Text="{Binding SimulationRunStateText}"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2.2*"/>
                <ColumnDefinition Width="1.1*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Padding="12" Background="White" BorderBrush="#FFD7DEE7" BorderThickness="1" CornerRadius="8" Margin="0,0,12,0">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top" Margin="0,0,0,10" Orientation="Horizontal">
                        <TextBlock FontSize="18" FontWeight="Bold" Text="Testschritte"/>
                        <Button Margin="12,0,0,0" Padding="12,6" Content="{Binding BreakpointButtonText}" Click="OnToggleBreakpoint" IsEnabled="{Binding CanToggleBreakpoint}"/>
                        <Button Margin="12,0,0,0" Padding="12,6" Content="Auswertungsanalyse" Click="OnShowEvaluationDetails" IsEnabled="{Binding CanOpenEvaluationDetails}"/>
                        <Button Margin="12,0,0,0" Padding="12,6" Content="Exportieren" Click="OnExportResults"/>
                        <Button Margin="12,0,0,0" Padding="12,6" Content="Snapshots speichern" Click="OnSaveSnapshotSession"/>
                        <Button Margin="12,0,0,0" Padding="12,6" Content="Snapshots laden" Click="OnLoadSnapshotSession"/>
                        <Button Margin="12,0,0,0" Padding="12,6" Content="Zu letztem Snapshot dieses Schritts" Click="OnJumpToSelectedStepSnapshot" IsEnabled="{Binding CanJumpToStepSnapshot}"/>
                    </StackPanel>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2.7*"/>
                                <ColumnDefinition Width="0.8*"/>
                                <ColumnDefinition Width="1.2*"/>
                                <ColumnDefinition Width="1.5*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" FontWeight="Bold" Text="Struktur"/>
                            <TextBlock Grid.Column="1" Margin="10,0,0,0" FontWeight="Bold" Text="Status / Quelle"/>
                            <TextBlock Grid.Column="2" Margin="10,0,0,0" FontWeight="Bold" Text="Ist"/>
                            <TextBlock Grid.Column="3" Margin="10,0,0,0" FontWeight="Bold" Text="Bereich"/>
                        </Grid>
                        <TreeView Grid.Row="1"
                                  ItemsSource="{Binding StepTreeRootNodes}"
                                  SelectedItemChanged="OnStepTreeSelected"
                                  MouseDoubleClick="OnStepTreeDoubleClick"
                                  Background="Transparent"
                                  BorderThickness="0"
                                  VirtualizingStackPanel.IsVirtualizing="True"
                                  VirtualizingStackPanel.VirtualizationMode="Recycling"/>
                    </Grid>
                </DockPanel>
            </Border>

            <Border Grid.Column="1" Padding="12" Background="#FFF8FBFD" BorderBrush="#FFD7DEE7" BorderThickness="1" CornerRadius="8">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top" Margin="0,0,0,10">
                        <TextBlock FontSize="18" FontWeight="Bold" Text="Snapshot-Timeline"/>
                        <TextBlock Margin="0,4,0,0" Foreground="#FF5A6470" Text="Globale Snapshot-Events fuer Schrittmodus, Concurrent-Analyse und Live-Zustand." TextWrapping="Wrap"/>
                    </StackPanel>
                    <ListBox ItemsSource="{Binding TimelineEntries}"
                             SelectedItem="{Binding SelectedTimelineEntry, Mode=TwoWay}"
                             AutomationProperties.AutomationId="SnapshotTimelineList">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,8" Padding="8" Background="#FFFFFFFF" BorderBrush="#FFE0E6EE" BorderThickness="1" CornerRadius="6">
                                    <StackPanel>
                                        <TextBlock FontWeight="Bold" Text="{Binding Label}"/>
                                        <TextBlock Margin="0,3,0,0" Foreground="#FF375A7F" Text="{Binding EventLabel}" TextWrapping="Wrap"/>
                                        <TextBlock Margin="0,3,0,0"
                                                   Foreground="#FF7C5E10"
                                                   FontSize="11"
                                                   Text="{Binding ComparisonLabel}"
                                                   TextWrapping="Wrap"
                                                   Visibility="{Binding HasComparisonLabel, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                        <TextBlock Margin="0,3,0,0" Foreground="#FF6C7886" FontSize="11" Text="{Binding BranchSummary}" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>
        </Grid>

        <Border Grid.Row="3" Margin="0,12,0,0" Padding="12" Background="#FFF9FAFB" BorderBrush="#FFD7DEE7" BorderThickness="1" CornerRadius="8">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Margin="0,0,0,10" FontWeight="Bold" Text="Protokoll"/>
                <ListBox ItemsSource="{Binding Logs}" AutomationProperties.AutomationId="LogList">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Width="70" FontWeight="Bold" Text="{Binding Timestamp, StringFormat={}{0:HH:mm:ss}}"/>
                                <TextBlock Text="{Binding Message}" TextWrapping="Wrap"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>
    </Grid>
</Window>
