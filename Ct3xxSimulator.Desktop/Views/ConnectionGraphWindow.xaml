<Window x:Class="Ct3xxSimulator.Desktop.Views.ConnectionGraphWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Verbindungsansicht"
        Height="760"
        Width="1220"
        Background="#FFF3F1EA"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="3.1*"/>
            <RowDefinition Height="1.2*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Padding="14"
                Background="#FFF8F4E8"
                BorderBrush="#FFD2C3A4"
                BorderThickness="1"
                CornerRadius="10">
            <StackPanel>
                <TextBlock x:Name="TitleTextBlock"
                           FontSize="22"
                           FontWeight="Bold"
                           Foreground="#FF3D3528"/>
                <TextBlock Margin="0,8,0,0"
                           Foreground="#FF5E564A"
                           Text="Mausrad zoomt, linke Maustaste verschiebt die Ansicht. Dargestellt wird der aktuell leitende Pfad fuer den gewaelten Testschritt. Ein Klick auf ein Untermodul oeffnet dessen internen Pfad."/>
            </StackPanel>
        </Border>

        <Grid Grid.Row="1" Margin="0,14,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Background="#FFF8F4E8"
                    BorderBrush="#FFD2C3A4"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock FontWeight="Bold" FontSize="16" Foreground="#FF3D3528" Text="Leitende Pfade"/>
                    <ListBox x:Name="TraceListBox"
                             Grid.Row="1"
                             Margin="0,10,0,0"
                             SelectionChanged="OnTraceSelectionChanged"
                             DisplayMemberPath="Title"/>
                </Grid>
            </Border>

            <Border Grid.Column="2"
                    Background="#FFFDFBF6"
                    BorderBrush="#FFD9CFBC"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <TextBlock x:Name="SelectedTraceTitleTextBlock"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="#FF3D3528"/>
                        <TextBlock x:Name="SelectedTraceSummaryTextBlock"
                                   Margin="0,6,0,0"
                                   Foreground="#FF5E564A"
                                   TextWrapping="Wrap"/>
                    </StackPanel>

                    <ItemsControl Grid.Row="1" Margin="0,12,0,12" x:Name="TraceNodeSummaryItemsControl">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,8,8"
                                        Padding="10,6"
                                        Background="#FFF5EEE0"
                                        BorderBrush="#FFD2C3A4"
                                        BorderThickness="1"
                                        CornerRadius="16">
                                    <TextBlock Text="{Binding}" Foreground="#FF4F4538"/>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Border Grid.Row="2"
                            Background="#FFFEFCF8"
                            BorderBrush="#FFE2D7C3"
                            BorderThickness="1"
                            CornerRadius="10"
                            ClipToBounds="True"
                            MouseWheel="OnViewportMouseWheel"
                            MouseLeftButtonDown="OnViewportMouseLeftButtonDown"
                            MouseMove="OnViewportMouseMove"
                            MouseLeftButtonUp="OnViewportMouseLeftButtonUp"
                            MouseLeave="OnViewportMouseLeftButtonUp">
                        <Grid Background="#FFFEFCF8">
                            <Canvas x:Name="GraphCanvas" Background="Transparent" RenderTransformOrigin="0,0">
                                <Canvas.RenderTransform>
                                    <TransformGroup>
                                        <ScaleTransform x:Name="GraphScaleTransform" ScaleX="1" ScaleY="1"/>
                                        <TranslateTransform x:Name="GraphTranslateTransform" X="0" Y="0"/>
                                    </TransformGroup>
                                </Canvas.RenderTransform>
                            </Canvas>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2"
                Background="#FFF8FBFD"
                BorderBrush="#FFD7DEE7"
                BorderThickness="1"
                CornerRadius="10"
                Padding="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock FontWeight="Bold" Text="Messverlauf"/>
                <Canvas Grid.Row="1" x:Name="CurveCanvas" Height="180" Background="#FFFDFEFF"/>
            </Grid>
        </Border>

        <DockPanel Grid.Row="3" Margin="0,14,0,0">
            <TextBlock x:Name="StatusTextBlock"
                       VerticalAlignment="Center"
                       Foreground="#FF5E564A"/>
            <Button DockPanel.Dock="Right"
                    Padding="16,8"
                    Content="Schliessen"
                    Click="OnClose"/>
        </DockPanel>
    </Grid>
</Window>
