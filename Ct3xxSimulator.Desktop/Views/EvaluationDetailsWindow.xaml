<Window x:Class="Ct3xxSimulator.Desktop.Views.EvaluationDetailsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Auswertungsansicht"
        Height="760"
        Width="1180"
        Background="#FFF5F7FA"
        WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <Style x:Key="MetricRowStyle" TargetType="DataGridRow">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#FF293241"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding Status}" Value="FAIL">
                    <Setter Property="Background" Value="#FFFDEDEE"/>
                    <Setter Property="Foreground" Value="#FF7F1D1D"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="ERROR">
                    <Setter Property="Background" Value="#FFFBE8EA"/>
                    <Setter Property="Foreground" Value="#FF8B1E3F"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="Zu klein">
                    <Setter Property="Background" Value="#FFFDF0F0"/>
                    <Setter Property="Foreground" Value="#FF8A2E2E"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="Zu gross">
                    <Setter Property="Background" Value="#FFFDF0F0"/>
                    <Setter Property="Foreground" Value="#FF8A2E2E"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="OK">
                    <Setter Property="Background" Value="#FFF5FBF5"/>
                    <Setter Property="Foreground" Value="#FF2D6A4F"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="PASS">
                    <Setter Property="Background" Value="#FFF5FBF5"/>
                    <Setter Property="Foreground" Value="#FF2D6A4F"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Padding="14"
                Background="#FFFDFEFE"
                BorderBrush="#FFD7DEE7"
                BorderThickness="1"
                CornerRadius="10">
            <StackPanel>
                <TextBlock x:Name="TitleTextBlock"
                           FontSize="22"
                           FontWeight="Bold"
                           Foreground="#FF293241"/>
                <TextBlock x:Name="SubtitleTextBlock"
                           Margin="0,8,0,0"
                           Foreground="#FF52606D"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <Grid Grid.Row="1" Margin="0,14,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.0*"/>
                <ColumnDefinition Width="1.2*"/>
                <ColumnDefinition Width="1.1*"/>
                <ColumnDefinition Width="1.1*"/>
                <ColumnDefinition Width="1.4*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Margin="0,0,12,0" Padding="12" Background="#FFF8FAFC" BorderBrush="#FFD4E1EE" BorderThickness="1" CornerRadius="8">
                <StackPanel>
                    <TextBlock Text="Quelle" FontWeight="Bold"/>
                    <TextBlock x:Name="ResultSourceTextBlock" Margin="0,6,0,0" FontSize="18" FontWeight="Bold"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Margin="0,0,12,0" Padding="12" Background="#FFF6FAF7" BorderBrush="#FFD3E4D4" BorderThickness="1" CornerRadius="8">
                <StackPanel>
                    <TextBlock Text="Ergebnis" FontWeight="Bold"/>
                    <TextBlock x:Name="OutcomeTextBlock" Margin="0,6,0,0" FontSize="18" FontWeight="Bold"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Margin="0,0,12,0" Padding="12" Background="#FFF9FBFE" BorderBrush="#FFD4E1EE" BorderThickness="1" CornerRadius="8">
                <StackPanel>
                    <TextBlock Text="Ist" FontWeight="Bold"/>
                    <TextBlock x:Name="MeasuredValueTextBlock" Margin="0,6,0,0" FontSize="18" FontWeight="Bold"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="3" Margin="0,0,12,0" Padding="12" Background="#FFFFFBF2" BorderBrush="#FFE6D6A8" BorderThickness="1" CornerRadius="8">
                <StackPanel>
                    <TextBlock Text="Sollbereich" FontWeight="Bold"/>
                    <TextBlock x:Name="RangeTextBlock" Margin="0,6,0,0" FontSize="18" FontWeight="Bold"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="4" Padding="12" Background="#FFFDFCF8" BorderBrush="#FFE2D7C3" BorderThickness="1" CornerRadius="8">
                <StackPanel>
                    <TextBlock Text="Hinweis" FontWeight="Bold"/>
                    <TextBlock x:Name="DetailsTextBlock" Margin="0,6,0,0" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>
        </Grid>

        <Grid Grid.Row="2">
            <TabControl x:Name="ReplayTabControl">
                <TabItem Header="Simulation">
                    <TabControl Margin="4">
                        <TabItem Header="Diagramm">
                            <Grid Margin="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="300"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Border Background="#FFFDFEFE" BorderBrush="#FFD7DEE7" BorderThickness="1" CornerRadius="10" Padding="10">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>
                                        <TextBlock FontWeight="Bold" FontSize="16" Text="Kurven"/>
                                        <ListBox x:Name="SeriesListBox"
                                                 Grid.Row="1"
                                                 Margin="0,10,0,0"
                                                 SelectionMode="Extended"
                                                 SelectionChanged="OnSeriesSelectionChanged"/>
                                    </Grid>
                                </Border>

                                <Border Grid.Column="2" Background="#FFFFFFFF" BorderBrush="#FFD7DEE7" BorderThickness="1" CornerRadius="10" Padding="12">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>
                                        <TextBlock x:Name="ChartTitleTextBlock" FontWeight="Bold" FontSize="16" Text="Kurvendiagramm"/>
                                        <Canvas Grid.Row="1" x:Name="ChartCanvas" Height="420" Background="#FFFDFEFF"/>
                                    </Grid>
                                </Border>
                            </Grid>
                        </TabItem>
                        <TabItem Header="Details">
                            <Grid Margin="8">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="12"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="12"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <Border Padding="10" Background="#FFFDFEFE" BorderBrush="#FFD7DEE7" BorderThickness="1" CornerRadius="10">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="160"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <TextBlock Grid.Row="0" FontWeight="Bold" Text="Ergebnis"/>
                                        <TextBlock x:Name="SummaryOutcomeTextBlock" Grid.Row="0" Grid.Column="1" TextWrapping="Wrap"/>
                                        <TextBlock Grid.Row="1" FontWeight="Bold" Text="Ist"/>
                                        <TextBlock x:Name="SummaryMeasuredValueTextBlock" Grid.Row="1" Grid.Column="1" TextWrapping="Wrap"/>
                                        <TextBlock Grid.Row="2" FontWeight="Bold" Text="Soll Min"/>
                                        <TextBlock x:Name="SummaryLowerLimitTextBlock" Grid.Row="2" Grid.Column="1" TextWrapping="Wrap"/>
                                        <TextBlock Grid.Row="3" FontWeight="Bold" Text="Soll Max"/>
                                        <TextBlock x:Name="SummaryUpperLimitTextBlock" Grid.Row="3" Grid.Column="1" TextWrapping="Wrap"/>
                                        <TextBlock Grid.Row="4" FontWeight="Bold" Text="Hinweis"/>
                                        <TextBlock x:Name="SummaryDetailsTextBlock" Grid.Row="4" Grid.Column="1" TextWrapping="Wrap"/>
                                    </Grid>
                                </Border>

                                <Border Grid.Row="2" Padding="10" Background="#FFFFFFFF" BorderBrush="#FFD7DEE7" BorderThickness="1" CornerRadius="10">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>
                                        <TextBlock FontWeight="Bold" FontSize="16" Text="Metrikdetails"/>
                                        <DataGrid x:Name="MetricsDataGrid"
                                                  Grid.Row="1"
                                                  Margin="0,10,0,0"
                                                  AutoGenerateColumns="False"
                                                  CanUserAddRows="False"
                                                  CanUserDeleteRows="False"
                                                  CanUserSortColumns="False"
                                                  IsReadOnly="True"
                                                  HeadersVisibility="Column"
                                                  GridLinesVisibility="Horizontal"
                                                  RowStyle="{StaticResource MetricRowStyle}">
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="Bereich / Kanal" Binding="{Binding Scope}" Width="130"/>
                                                <DataGridTextColumn Header="Merkmal" Binding="{Binding Metric}" Width="120"/>
                                                <DataGridTextColumn Header="Ist" Binding="{Binding Actual}" Width="120"/>
                                                <DataGridTextColumn Header="Soll Min" Binding="{Binding LowerLimit}" Width="120"/>
                                                <DataGridTextColumn Header="Soll Max" Binding="{Binding UpperLimit}" Width="120"/>
                                                <DataGridTextColumn Header="Einheit" Binding="{Binding Unit}" Width="90"/>
                                                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="100"/>
                                                <DataGridTextColumn Header="Hinweis" Binding="{Binding Note}" Width="*"/>
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </Grid>
                                </Border>

                                <Expander Grid.Row="4" Header="Rohdetails" IsExpanded="False">
                                    <Border Padding="10" Background="#FFFDFEFE" BorderBrush="#FFD7DEE7" BorderThickness="1" CornerRadius="10">
                                        <TextBlock x:Name="RawDetailsTextBlock" TextWrapping="Wrap"/>
                                    </Border>
                                </Expander>
                            </Grid>
                        </TabItem>
                    </TabControl>
                </TabItem>
                <TabItem Header="CSV">
                    <Grid Margin="12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="12"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="12"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Border Padding="10" Background="#FFFDFEFE" BorderBrush="#FFD7DEE7" BorderThickness="1" CornerRadius="10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="170"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" FontWeight="Bold" Text="CSV-Zeile"/>
                                <TextBlock x:Name="CsvRowTextBlock" Grid.Row="0" Grid.Column="1" TextWrapping="Wrap"/>
                                <TextBlock Grid.Row="1" FontWeight="Bold" Text="Ergebnis"/>
                                <TextBlock x:Name="CsvOutcomeTextBlock" Grid.Row="1" Grid.Column="1" TextWrapping="Wrap"/>
                                <TextBlock Grid.Row="2" FontWeight="Bold" Text="Wert"/>
                                <TextBlock x:Name="CsvMeasuredValueTextBlock" Grid.Row="2" Grid.Column="1" TextWrapping="Wrap"/>
                                <TextBlock Grid.Row="3" FontWeight="Bold" Text="Sollbereich"/>
                                <TextBlock x:Name="CsvRangeTextBlock" Grid.Row="3" Grid.Column="1" TextWrapping="Wrap"/>
                                <TextBlock Grid.Row="4" FontWeight="Bold" Text="Beschreibung"/>
                                <TextBlock x:Name="CsvDescriptionTextBlock" Grid.Row="4" Grid.Column="1" TextWrapping="Wrap"/>
                                <TextBlock Grid.Row="5" FontWeight="Bold" Text="Message"/>
                                <TextBlock x:Name="CsvMessageTextBlock" Grid.Row="5" Grid.Column="1" TextWrapping="Wrap"/>
                            </Grid>
                        </Border>

                        <Border Grid.Row="2" Padding="10" Background="#FFFFFFFF" BorderBrush="#FFD7DEE7" BorderThickness="1" CornerRadius="10">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <TextBlock FontWeight="Bold" FontSize="16" Text="CSV-Details"/>
                                <DataGrid x:Name="CsvMetricsDataGrid"
                                          Grid.Row="1"
                                          Margin="0,10,0,0"
                                          AutoGenerateColumns="False"
                                          CanUserAddRows="False"
                                          CanUserDeleteRows="False"
                                          CanUserSortColumns="False"
                                          IsReadOnly="True"
                                          HeadersVisibility="Column"
                                          GridLinesVisibility="Horizontal"
                                          RowStyle="{StaticResource MetricRowStyle}">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Bereich / Kanal" Binding="{Binding Scope}" Width="130"/>
                                        <DataGridTextColumn Header="Merkmal" Binding="{Binding Metric}" Width="120"/>
                                        <DataGridTextColumn Header="Ist" Binding="{Binding Actual}" Width="120"/>
                                        <DataGridTextColumn Header="Soll Min" Binding="{Binding LowerLimit}" Width="120"/>
                                        <DataGridTextColumn Header="Soll Max" Binding="{Binding UpperLimit}" Width="120"/>
                                        <DataGridTextColumn Header="Einheit" Binding="{Binding Unit}" Width="90"/>
                                        <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="100"/>
                                        <DataGridTextColumn Header="Hinweis" Binding="{Binding Note}" Width="*"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </Border>

                        <Expander Grid.Row="4" Header="CSV-Rohtext" IsExpanded="False">
                            <Border Padding="10" Background="#FFFDFEFE" BorderBrush="#FFD7DEE7" BorderThickness="1" CornerRadius="10">
                                <TextBlock x:Name="CsvRawDetailsTextBlock" TextWrapping="Wrap"/>
                            </Border>
                        </Expander>
                    </Grid>
                </TabItem>
                <TabItem Header="Vergleich">
                    <Grid Margin="12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="12"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Border Padding="10" Background="#FFFDFEFE" BorderBrush="#FFD7DEE7" BorderThickness="1" CornerRadius="10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="170"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Column="1" FontWeight="Bold" Text="Simulation"/>
                                <TextBlock Grid.Column="2" FontWeight="Bold" Text="CSV"/>

                                <TextBlock Grid.Row="1" FontWeight="Bold" Text="Ergebnis"/>
                                <TextBlock x:Name="CompareOutcomeSimTextBlock" Grid.Row="1" Grid.Column="1" TextWrapping="Wrap"/>
                                <TextBlock x:Name="CompareOutcomeCsvTextBlock" Grid.Row="1" Grid.Column="2" TextWrapping="Wrap"/>
                                <TextBlock Grid.Row="2" FontWeight="Bold" Text="Ist"/>
                                <TextBlock x:Name="CompareMeasuredSimTextBlock" Grid.Row="2" Grid.Column="1" TextWrapping="Wrap"/>
                                <TextBlock x:Name="CompareMeasuredCsvTextBlock" Grid.Row="2" Grid.Column="2" TextWrapping="Wrap"/>
                                <TextBlock Grid.Row="3" FontWeight="Bold" Text="Sollbereich"/>
                                <TextBlock x:Name="CompareRangeSimTextBlock" Grid.Row="3" Grid.Column="1" TextWrapping="Wrap"/>
                                <TextBlock x:Name="CompareRangeCsvTextBlock" Grid.Row="3" Grid.Column="2" TextWrapping="Wrap"/>
                                <TextBlock Grid.Row="4" FontWeight="Bold" Text="Hinweis"/>
                                <TextBlock x:Name="CompareDetailsSimTextBlock" Grid.Row="4" Grid.Column="1" TextWrapping="Wrap"/>
                                <TextBlock x:Name="CompareDetailsCsvTextBlock" Grid.Row="4" Grid.Column="2" TextWrapping="Wrap"/>
                            </Grid>
                        </Border>

                        <Border Grid.Row="2" Padding="10" Background="#FFFFFFFF" BorderBrush="#FFD7DEE7" BorderThickness="1" CornerRadius="10">
                            <StackPanel>
                                <TextBlock FontWeight="Bold" FontSize="16" Text="Vergleichszusammenfassung"/>
                                <TextBlock x:Name="ComparisonSummaryTextBlock" Margin="0,10,0,0" TextWrapping="Wrap"/>
                                <TextBlock x:Name="ComparisonModeTextBlock" Margin="0,8,0,0" Foreground="#FF52606D" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </TabItem>
            </TabControl>
        </Grid>

        <DockPanel Grid.Row="3" Margin="0,14,0,0">
            <TextBlock x:Name="StatusTextBlock"
                       VerticalAlignment="Center"
                       Foreground="#FF52606D"/>
            <Button DockPanel.Dock="Right"
                    Padding="16,8"
                    Content="Schliessen"
                    Click="OnClose"/>
        </DockPanel>
    </Grid>
</Window>
